{
  "id": "neo4j-mcp",
  "name": "Neo4j MCP",
  "description": "Neo4j graph database for knowledge graphs — run Cypher queries, traverse relationships, and build citation or concept graphs for research.",
  "category": "database",
  "install": {
    "runtime": "python",
    "package": "mcp-neo4j",
    "command": "pip install mcp-neo4j"
  },
  "config": {
    "env": {
      "NEO4J_URI": {
        "description": "Neo4j connection URI (e.g. bolt://localhost:7687)",
        "required": true
      },
      "NEO4J_USERNAME": {
        "description": "Neo4j database username",
        "required": true
      },
      "NEO4J_PASSWORD": {
        "description": "Neo4j database password",
        "required": true
      }
    }
  },
  "tools": [
    "run_cypher_query",
    "get_node",
    "get_relationships",
    "create_node",
    "create_relationship",
    "get_schema"
  ],
  "verified": false,
  "source": "https://github.com/neo4j-contrib/mcp-neo4j"
}
