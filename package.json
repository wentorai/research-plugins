{
  "name": "@wentorai/research-plugins",
  "version": "1.4.2",
  "type": "module",
  "description": "438 academic research skills, 34 agent tools across 18 API modules, and 6 curated lists for Research-Claw and AI agents",
  "keywords": [
    "agent-skills",
    "claude",
    "academic",
    "research",
    "scientific-writing",
    "literature-review",
    "research-claw",
    "wentor",
    "ai4s",
    "openclaw"
  ],
  "files": [
    "skills/",
    "curated/",
    "src/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "validate": "node --experimental-strip-types scripts/validate.ts",
    "catalog": "node --experimental-strip-types scripts/catalog.ts"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "license": "MIT",
  "homepage": "https://wentor.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/wentorai/research-plugins"
  }
}
