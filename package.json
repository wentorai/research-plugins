{
  "name": "@wentorai/research-plugins",
  "version": "1.1.0",
  "type": "module",
  "description": "372 academic research skills, 76 MCP configs, and 13 agent tools for Research-Claw and AI agents",
  "keywords": [
    "agent-skills",
    "claude",
    "cursor",
    "windsurf",
    "opencode",
    "academic",
    "research",
    "scientific-writing",
    "literature-review",
    "research-claw",
    "wentor",
    "ai4s",
    "openclaw"
  ],
  "files": [
    "skills/",
    "mcp-configs/",
    "curated/",
    "src/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "validate": "node --experimental-strip-types scripts/validate.ts",
    "catalog": "node --experimental-strip-types scripts/catalog.ts",
    "sync-registry": "node --experimental-strip-types scripts/sync-registry.ts"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "license": "MIT",
  "homepage": "https://wentor.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/wentorai/research-plugins"
  }
}
