{
  "id": "gitlab-mcp",
  "name": "GitLab MCP",
  "description": "GitLab project management — manage repositories, issues, merge requests, and CI/CD pipelines for research software development.",
  "category": "dev-platform",
  "install": {
    "runtime": "node",
    "package": "mcp-server-gitlab",
    "command": "npm install mcp-server-gitlab"
  },
  "config": {
    "env": {
      "GITLAB_TOKEN": {
        "description": "GitLab personal access token",
        "required": true
      },
      "GITLAB_URL": {
        "description": "GitLab instance URL (defaults to https://gitlab.com)",
        "required": false
      }
    }
  },
  "tools": [
    "list_projects",
    "get_project",
    "list_issues",
    "create_issue",
    "list_merge_requests",
    "get_file_contents",
    "search_projects"
  ],
  "verified": false,
  "source": "https://github.com/theailanguage/mcp-server-gitlab"
}
