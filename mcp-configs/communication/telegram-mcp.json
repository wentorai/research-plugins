{
  "id": "telegram-mcp",
  "name": "Telegram MCP",
  "description": "Telegram bot integration — send and receive messages, manage groups, and share files through Telegram for research collaboration.",
  "category": "communication",
  "install": {
    "runtime": "node",
    "package": "mcp-telegram",
    "command": "npm install mcp-telegram"
  },
  "config": {
    "env": {
      "TELEGRAM_BOT_TOKEN": {
        "description": "Telegram bot token from @BotFather",
        "required": true
      }
    }
  },
  "tools": [
    "send_message",
    "read_updates",
    "send_document",
    "get_chat_info",
    "list_chat_members"
  ],
  "verified": false,
  "source": "https://github.com/nicekid1/mcp-telegram"
}
